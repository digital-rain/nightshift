# Nightshift environment — copy to .env and edit. Secrets live here only;
# .env is gitignored. See docs/user/configuration-reference.md for every knob.

# The workspace that parents your target repos + the nightshift-tasks content
# store. Shared by the manager and any co-located worker. Absolute path or
# $HOME/... (a literal "~" is not expanded). Defaults to the repo dir.
#NIGHTSHIFT_WORKSPACE=$HOME/workspaces

# Where workers find the manager (also used by a co-located worker).
#NIGHTSHIFT_MANAGER_URL=http://localhost:8800

# Durable state (recommended). Nightshift's own DSN — a clean, dedicated DB.
# Omit to use the in-memory fallback (state lost on restart).
#NIGHTSHIFT_PG_DSN=postgresql://nightshift:nightshift@127.0.0.1:5432/nightshift

# Shared secret protecting the manager's worker API. Set the same value on the
# manager and every worker when the manager is exposed beyond localhost.
#NIGHTSHIFT_SHARED_SECRET=

# ── Backend credentials (only the ones this box's worker uses) ──────────
# anthropic backend, the in-house harness, and enhance-on-create.
#ANTHROPIC_API_KEY=sk-ant-...
# antigravity backend: authenticate with `agy` (Google OAuth); no API key env var.
# ollama-cloud backend (create at https://ollama.com/settings/keys).
#OLLAMA_API_KEY=

# ── Worker identity/overrides (env wins over .nightshift/worker.json) ───
# Required by `just worker` / `just worker-headless` — stable unique id per box.
NIGHTSHIFT_WORKER_ID=vm-1
#NIGHTSHIFT_WORKER_MODELS=claude-code/claude-sonnet-4-6,claude-code/claude-opus-4-8
#NIGHTSHIFT_WORKER_QUEUES=
#NIGHTSHIFT_RENDEZVOUS_REMOTE=origin

# ── Slack capture daemon (just slackd; needs `uv sync --extra slack`) ───
#SLACK_BOT_TOKEN=xoxb-...
#SLACK_APP_TOKEN=xapp-...
